# Sécurité
# Clé secrète utilisée pour signer les tokens JWT (authentification)
SECRET_KEY=generate_a_secure_random_key_here

# Durée de validité du token d’accès (en minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080 #7 jours

# Configuration de la base de données (PostgreSQL / PostGIS)
# Adresse du serveur PostgreSQL (local ou distant)
POSTGRES_SERVER=localhost
POSTGRES_USER=etp_user
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=etp_db

# Si elle n’est pas définie, elle sera automatiquement construite à partir des variables ci-dessus
# DATABASE_URL=postgresql+asyncpg://etp_user:your_secure_db_password@localhost:5432/etp_db

# Redis (Cache & Celery Broker)
REDIS_URL=redis://localhost:6379/0

# Stockage d’objets (MinIO / S3)
# Endpoint du serveur de stockage de fichiers (compatible S3)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key
MINIO_BUCKET_NAME=etp-documents

# CORS 
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
